                                     # ─── Convex ───────────────────────────────────────────────────────────────────
# Set automatically by `npx convex dev` or Convex dashboard
VITE_CONVEX_URL=

# Auth JWT private key (RSA 2048, generated by convex auth init)
# JWT_PRIVATE_KEY=

# ─── AI Models ────────────────────────────────────────────────────────────────
# At least one is required. DeepSeek is the cheapest default.

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI / Grok — https://console.x.ai
XAI_API_KEY=

# Moonshot / Kimi — https://platform.moonshot.cn
MOONSHOT_API_KEY=

# OpenAI (fallback) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Required for auth email (OTP & password reset)
# Get your key at https://resend.com — free tier is 3,000 emails/month
RESEND_API_KEY=

# From address — use resend's default for testing, or your verified domain in prod
# EMAIL_FROM=auth@yourdomain.com

# ─── Dev / Preview ────────────────────────────────────────────────────────────
# Set to "true" to enable test credential login (dev only, never in production)
# IS_PREVIEW=true
